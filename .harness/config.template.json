{
  "_comment": "Template for CAP harness config. Generated config lives at ~/.claude-platform/harness-config.json. Run 'cap init' to configure.",
  "provider": "aws-bedrock",
  "aws": {
    "profile": "__SET_BY_CAP_INIT__",
    "region": "eu-central-1",
    "auth_method": "sso-profile"
  },
  "anthropic": {
    "_comment": "Used when provider=anthropic-api. API key is NEVER stored here — only the env var name.",
    "api_key_env": "ANTHROPIC_API_KEY"
  },
  "azure": {
    "_comment": "Used when provider=azure-openai.",
    "endpoint": "",
    "api_key_env": "AZURE_OPENAI_API_KEY",
    "deployments": {
      "haiku": "claude-haiku",
      "sonnet": "claude-sonnet",
      "opus": "claude-opus"
    }
  },
  "local": {
    "_comment": "Used when provider=local (Ollama, vLLM, etc.).",
    "base_url": "http://localhost:11434",
    "models": {
      "haiku": "llama3",
      "sonnet": "codestral",
      "opus": "llama3:70b"
    }
  },
  "models": {
    "haiku": "eu.anthropic.claude-haiku-4-5-20251001-v1:0",
    "sonnet": "eu.anthropic.claude-sonnet-4-5-20250929-v1:0",
    "opus": "eu.anthropic.claude-opus-4-6-v1"
  },
  "budget": {
    "daily_limit_usd": 5.0,
    "alert_threshold_pct": 80
  },
  "agent_defaults": {
    "dev": "sonnet",
    "devops": "sonnet",
    "security": "opus",
    "code-review": "opus",
    "sre": "sonnet",
    "test": "sonnet",
    "docs": "haiku",
    "optimization": "haiku",
    "aws-architect": "opus",
    "explore": "sonnet",
    "cicd": "sonnet"
  },
  "execution": {
    "max_tool_iterations": 15,
    "max_retries": 2,
    "backoff_base_s": 1.0,
    "default_max_tokens": 8192,
    "temperature": 0.7
  }
}
