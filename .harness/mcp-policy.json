{
  "$comment": "CAP default MCP governance policy. Copied to workspace/.harness/ during cap init. Edit the workspace copy to customize per-project.",

  "schema": 1,
  "policyVersion": 1,
  "harnessId": "cap-harness",

  "defaultDeny": true,

  "allowShell": false,
  "allowNetwork": false,
  "allowFileWrite": false,

  "requireApprovalForDangerous": true,
  "auditLog": true,

  "toolTimeoutMs": 600000,
  "maxToolCallsPerTurn": 200,
  "dailyBudgetUsd": 5.0,

  "dangerousPatterns": [
    "rm\\s+-rf",
    "sudo\\b",
    "git\\s+push.*--force",
    "DROP\\s+TABLE",
    "DELETE\\s+FROM.*WHERE\\s+1",
    "chmod\\s+777",
    "curl.*\\|.*sh",
    "eval\\("
  ],

  "approvedServers": [
    "cap-harness"
  ]
}
