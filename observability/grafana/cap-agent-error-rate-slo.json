{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus / Mimir",
      "description": "CAP platform Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "CAP Platform — Agent Dispatch Error Rate, Circuit Breakers, Cascade Events, Error Budget",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "Runbooks",
      "tooltip": "Open runbook directory",
      "type": "link",
      "url": "https://github.com/your-org/claude-agent-platform/tree/main/observability/runbooks"
    }
  ],
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Platform Error Rate (5m)",
      "description": "Platform-wide agent dispatch error rate over the last 5 minutes. SLO target: < 0.5%.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.20 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "cap:platform_error_rate:5m",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "type": "gauge",
      "title": "Error Budget Remaining (30-day)",
      "description": "Fraction of the 30-day error budget remaining. SLO: 99.5% success. Budget = 0.5% of requests.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "yellow", "value": 0.50 },
              { "color": "green",  "value": 0.75 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "clamp_min(1 - (cap:error_budget_burn_rate:6h * (6 / (30 * 24))), 0)",
          "legendFormat": "Budget Remaining",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Error Budget Burn Rate (1h)",
      "description": "Current burn rate relative to sustainable pace. > 14× triggers P1 alert.",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "noValue": "0×",
          "displayName": "Burn Rate",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 10 },
              { "color": "red",    "value": 14 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "cap:error_budget_burn_rate:1h",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Circuit Breakers OPEN",
      "description": "Number of agent types currently in OPEN (blocking) circuit breaker state.",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(cap_circuit_breaker_state{state=\"OPEN\"} == 1) or vector(0)",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Cascade Events (1h)",
      "description": "Number of cascade failure events detected in the last hour.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(cap_cascade_events_total[1h])",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Dispatch Queue Depth",
      "description": "Current pending agent dispatch tasks. >50 triggers saturation alert.",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "orange", "value": 35 },
              { "color": "red",    "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "cap_agent_dispatch_queue_depth",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Agent Error Rate by Type (5m)",
      "description": "Dispatch error rate per agent_type. Dashed lines = P2 (5%) and P1 (20%) thresholds.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "orange", "value": 0.05 },
              { "color": "red",    "value": 0.20 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "cap:agent_error_rate:5m",
          "legendFormat": "{{ agent_type }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vector(0.05)",
          "legendFormat": "P2 threshold (5%)",
          "refId": "B",
          "hide": false
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vector(0.20)",
          "legendFormat": "P1 threshold (20%)",
          "refId": "C",
          "hide": false
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Error Budget Burn Rate",
      "description": "Multi-window burn rates. P1 fires when 1h > 14× AND 6h > 5×.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Burn Rate (1h)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Burn Rate (6h)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "cap:error_budget_burn_rate:1h",
          "legendFormat": "Burn Rate (1h)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "cap:error_budget_burn_rate:6h",
          "legendFormat": "Burn Rate (6h)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vector(14)",
          "legendFormat": "P1 threshold (14×, 1h)",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vector(5)",
          "legendFormat": "P2 threshold (5×, 6h)",
          "refId": "D"
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Dispatch Rate — Completed vs Failed",
      "description": "Absolute dispatch throughput. Gaps indicate stalls.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Completed" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(cap_agent_dispatch_total{outcome=\"completed\"}[5m]))",
          "legendFormat": "Completed",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(cap_agent_dispatch_total{outcome=\"failed\"}[5m]))",
          "legendFormat": "Failed",
          "refId": "B"
        }
      ]
    },

    {
      "id": 10,
      "type": "table",
      "title": "Circuit Breaker State per Agent Type",
      "description": "Current circuit breaker states. OPEN = dispatches blocked.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "footer": { "show": false },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "OPEN":      { "color": "red",    "index": 0 } } },
                  { "type": "value", "options": { "HALF_OPEN": { "color": "orange", "index": 1 } } },
                  { "type": "value", "options": { "CLOSED":    { "color": "green",  "index": 2 } } }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "cap_circuit_breaker_state",
          "legendFormat": "{{ agent_type }} — {{ state }}",
          "refId": "A",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "organize", "options": { "excludeByName": { "__name__": true, "job": true, "instance": true }, "renameByName": { "agent_type": "Agent Type", "state": "State", "Value": "Active" } } }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["cap", "sre", "error-rate", "circuit-breaker"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(cap_agent_dispatch_total, agent_type)",
        "hide": 0,
        "includeAll": true,
        "label": "Agent Type",
        "multi": true,
        "name": "agent_type",
        "query": {
          "query": "label_values(cap_agent_dispatch_total, agent_type)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "CAP Platform — Agent Error Rate & SLO",
  "uid": "cap-agent-error-rate-slo",
  "version": 1
}
